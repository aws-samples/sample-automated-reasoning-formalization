{
  "name": "architect",
  "productName": "ARchitect",
  "version": "0.1.0",
  "description": "ARchitect - Automated Reasoning policy editor for Amazon Bedrock Guardrails",
  "main": ".webpack/main",
  "license": "MIT-0",
  "scripts": {
    "start": "electron-forge start",
    "start:debug": "ARCHITECT_DEBUG=1 electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint src/",
    "test": "vitest --run",
    "test:acp": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "benchmark": "npx tsx benchmarks/src/benchmark-runner.ts",
    "benchmark:generate-report": "npx tsx benchmarks/src/generate-report-cli.ts",
    "benchmark:cleanup": "npx tsx benchmarks/src/cleanup-orphaned-policies.ts"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "css-loader": "^7.1.2",
    "electron": "^40.6.1",
    "fast-check": "^4.5.3",
    "jsdom": "^27.0.1",
    "mini-css-extract-plugin": "^2.10.2",
    "node-loader": "^2.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.996.0",
    "@aws-sdk/client-bedrock-runtime": "^3.996.0",
    "@aws-sdk/credential-providers": "^3.996.0",
    "@cloudscape-design/chat-components": "^1.0.100",
    "@cloudscape-design/collection-hooks": "^1.0.84",
    "@cloudscape-design/components": "^3.0.1218",
    "@cloudscape-design/design-tokens": "^3.0.73",
    "@cloudscape-design/global-styles": "^1.0.51",
    "dompurify": "^3.3.3",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "tar": "7.5.13",
    "@tootallnate/once": "3.0.1",
    "tmp": "0.2.5",
    "webpack-dev-server": "5.2.3"
  }
}
